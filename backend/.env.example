# Copy to .env (gitignored). NEVER commit real secrets.
DATABASE_URL=postgres://xend:xend@localhost:5432/xend
REDIS_URL=redis://localhost:6379
RUST_LOG=info

# The only place RPC credentials live; the device never sees these. Defaults to public
# devnet if unset. Swap in a Helius/QuickNode URL to lift rate limits.
SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_WSS_URL=wss://api.devnet.solana.com   # used by the confirmation stream (Phase 5)

# Comma-separated API keys accepted by the gateway (Authorization: Bearer <key>). Leave
# unset ONLY for local development — that disables authentication. Set real keys in prod.
# XEND_API_KEYS=sk_live_key_one,sk_live_key_two

# Address the server binds to. Defaults to 0.0.0.0:8080.
# XEND_ADDR=0.0.0.0:8080
